<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙️ AI Settings"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1a237e"
            android:paddingBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Choose AI Provider:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingBottom="12dp" />

        <RadioGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="16dp">

            <RadioButton
                android:id="@+id/radioGemini"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🤖 Google Gemini (Free API Key)"
                android:textSize="15sp"
                android:checked="true" />

            <RadioButton
                android:id="@+id/radioOllama"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🦙 Ollama (Self-hosted or Cloud)"
                android:textSize="15sp"
                android:paddingTop="8dp" />
        </RadioGroup>

        <!-- Gemini Settings -->
        <LinearLayout
            android:id="@+id/layoutGemini"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Get a free key from aistudio.google.com/apikey"
                android:textSize="13sp"
                android:textColor="#666"
                android:paddingBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Gemini API Key">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:fontFamily="monospace" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Ollama Settings -->
        <LinearLayout
            android:id="@+id/layoutOllama"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enter your Ollama server URL and model name.\n\nLocal: http://localhost:11434\nCloud: your server URL"
                android:textSize="13sp"
                android:textColor="#666"
                android:paddingBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ollama Server URL"
                android:paddingBottom="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etOllamaUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:text="http://localhost:11434"
                    android:fontFamily="monospace" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Model Name"
                android:paddingBottom="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etOllamaModel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:text="llama3"
                    android:fontFamily="monospace" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Popular models: llama3, mistral, gemma2, qwen2, phi3, codellama, meditron"
                android:textSize="12sp"
                android:textColor="#888"
                android:paddingBottom="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <Button
                android:id="@+id/btnTest"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔍 Test"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💾 Save" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No AI provider configured"
            android:textSize="14sp"
            android:textColor="#666"
            android:padding="12dp"
            android:background="#f5f6fa" />
    </LinearLayout>
</ScrollView>
