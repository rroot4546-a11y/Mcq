<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙️ AI Settings"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:paddingBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Choose AI Provider:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingBottom="12dp" />

        <RadioGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="16dp">

            <RadioButton
                android:id="@+id/radioGemini"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🤖 Google Gemini (Free API Key)"
                android:textSize="15sp"
                android:checked="true"
                android:paddingBottom="4dp" />

            <RadioButton
                android:id="@+id/radioOllama"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🦙 Ollama (Self-hosted or Cloud)"
                android:textSize="15sp"
                android:paddingBottom="4dp" />

            <RadioButton
                android:id="@+id/radioCustom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔧 Custom AI (OpenAI-compatible API)"
                android:textSize="15sp" />
        </RadioGroup>

        <!-- Gemini -->
        <LinearLayout
            android:id="@+id/layoutGemini"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Free key from aistudio.google.com/apikey"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:paddingBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Gemini API Key">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:fontFamily="monospace" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Ollama -->
        <LinearLayout
            android:id="@+id/layoutOllama"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Local: http://localhost:11434\nCloud: your server URL"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:paddingBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ollama Server URL"
                android:paddingBottom="8dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etOllamaUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:fontFamily="monospace" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Model Name">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etOllamaModel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:fontFamily="monospace" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Custom AI -->
        <LinearLayout
            android:id="@+id/layoutCustom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Any OpenAI-compatible API:\nOpenRouter, Together AI, Groq, local LLMs, etc.\n\nURL format: https://api.example.com/v1/chat/completions"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:paddingBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="API Base URL"
                android:paddingBottom="8dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCustomUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:fontFamily="monospace" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Model Name (e.g. gpt-4o, claude-3, llama-3)"
                android:paddingBottom="8dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCustomModel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:fontFamily="monospace" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="API Key (if required)">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCustomApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:fontFamily="monospace" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="20dp"
            android:paddingBottom="16dp">

            <Button
                android:id="@+id/btnTest"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔍 Test"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💾 Save" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No AI provider configured"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:padding="12dp"
            android:background="@color/divider" />
    </LinearLayout>
</ScrollView>
